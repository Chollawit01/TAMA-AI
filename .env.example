# ====================================================
# TAMA AI - Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ====================================================

# --- Gemini AI ---
# สมัครที่: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- LINE Messaging API ---
# สมัครที่: https://developers.line.biz/console/
# 1. สร้าง Provider > สร้าง Messaging API Channel
# 2. ไปที่ Messaging API tab > copy Channel access token
# 3. ไปที่ Basic settings > copy Channel secret & Channel ID
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token-here
LINE_CHANNEL_SECRET=your-channel-secret-here
LINE_CHANNEL_ID=your-channel-id-here

# --- Gold API (Optional) ---
# สมัครที่: https://www.goldapi.io/ (Free tier: 300 requests/month)
GOLD_API_KEY=

# --- X (Twitter) API (Optional แต่แนะนำ) ---
# ใช้ติดตามโพสต์ของ Elon Musk & Trump แบบ real-time
# สมัครที่: https://developer.x.com/en/portal/dashboard
# 1. สร้าง Project & App
# 2. ไปที่ Keys and tokens > Bearer Token
# หากไม่มี จะใช้ RSSHub fallback (อาจช้ากว่า)
X_BEARER_TOKEN=

# --- Schedule ---
# Cron format: ทุก 1 ชั่วโมง (นาทีที่ 0)
# ตัวอย่าง: "0 * * * *" = ทุกชั่วโมง, "*/30 * * * *" = ทุก 30 นาที
CRON_SCHEDULE=0 * * * *

# Social Monitor: ตรวจโพสต์ Elon & Trump ทุก 5 นาที
SOCIAL_CRON_SCHEDULE=*/5 * * * *

# --- Options ---
# รันทันทีเมื่อเริ่มโปรแกรม (true/false)
RUN_ON_START=true

# --- Logging ---
LOG_LEVEL=info
